# ---------------------------------------------------------------------------
# Variaveis usadas pelo docker-compose.yml (substituicao ${VAR}).
# Copie este arquivo para .env e ajuste os valores:
#   cp .env.example .env
# O arquivo .env NAO e versionado (contem segredos reais).
# ---------------------------------------------------------------------------

# --- PostgreSQL (servico db) ---
POSTGRES_DB=carworkshop
POSTGRES_USER=carworkshop
POSTGRES_PASSWORD=troque-esta-senha

# --- Backend ---
# Segredo do JWT (obrigatorio; use um valor longo e aleatorio)
JWT_SECRET=troque-por-um-segredo-longo-e-aleatorio
# Usuario administrador inicial criado no primeiro startup
APP_ADMIN_LOGIN=admin@example.com
APP_ADMIN_PASSWORD=troque-esta-senha

# --- Portas expostas no host ---
FRONTEND_PORT=5173
BACKEND_PORT=8080
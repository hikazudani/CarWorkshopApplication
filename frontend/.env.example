# ---------------------------------------------------------------------------
# Variaveis de ambiente do frontend (Vite).
# Copie este arquivo para .env e ajuste conforme o seu ambiente:
#   cp .env.example .env
# Apenas variaveis com prefixo VITE_ ficam expostas ao codigo do navegador.
# ---------------------------------------------------------------------------

# Base URL usada pelo cliente axios.
# Vazio (padrao) = usa o proxy do Vite (recomendado em desenvolvimento).
# Em producao, aponte para a URL publica do backend, ex.: https://api.exemplo.com
VITE_API_BASE_URL=

# Alvo do proxy de dev do Vite: para onde /login e /consertos sao repassados.
VITE_BACKEND_URL=http://localhost:8080

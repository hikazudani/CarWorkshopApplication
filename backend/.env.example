# ---------------------------------------------------------------------------
# Variaveis de ambiente do backend (Spring Boot).
#
# O projeto usa a dependencia spring-dotenv: este arquivo .env e carregado
# automaticamente como property source na inicializacao. O application.properties
# consome os valores no formato ${VAR:valor_padrao}, entao variaveis ausentes
# caem nos padrao de desenvolvimento.
#
# Para usar: copie este arquivo para .env (no diretorio backend/) e ajuste:
#   cp .env.example .env
#
# Variaveis exportadas no ambiente do SO tem precedencia sobre o arquivo .env.
# ---------------------------------------------------------------------------

# Porta em que a API sobe
SERVER_PORT=8080

# Banco de dados (padrao: H2 em arquivo)
DB_URL=jdbc:h2:file:./DATA/pw3api
DB_USERNAME=sa
DB_PASSWORD=

# Console web do H2 (true/false)
H2_CONSOLE_ENABLED=true

# Para usar PostgreSQL (ex.: rodando o banco em container), use algo como:
# DB_URL=jdbc:postgresql://localhost:5432/carworkshop
# DB_USERNAME=carworkshop
# DB_PASSWORD=troque-esta-senha
# H2_CONSOLE_ENABLED=false

# Segredo do JWT (OBRIGATORIO; a app nao sobe sem ele).
# Use um valor longo e aleatorio. Exemplo abaixo e apenas placeholder.
JWT_SECRET=troque-por-um-segredo-longo-e-aleatorio

# Usuario administrador inicial (criado no startup se nao existir).
# Defina valores reais aqui; estes sao apenas exemplos/placeholders.
APP_ADMIN_LOGIN=admin@example.com
APP_ADMIN_PASSWORD=troque-esta-senha